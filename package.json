{
  "name": "gridbash",
  "version": "0.1.5",
  "description": "Windows-native terminal grid for running Codex, Claude, Gemini, and other CLI agents side by side.",
  "license": "MIT",
  "homepage": "https://jasonsuhari.github.io/gridbash/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonsuhari/gridbash.git"
  },
  "bugs": {
    "url": "https://github.com/jasonsuhari/gridbash/issues"
  },
  "bin": {
    "gridbash": "npm/bin/gridbash.js"
  },
  "files": [
    "npm/bin/",
    "docs/devlogs/",
    "docs/releases/",
    "docs/RELEASING.md",
    "README.md",
    "LICENSE",
    "config.example.toml"
  ],
  "scripts": {
