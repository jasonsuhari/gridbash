{
  "name": "gridbash",
  "version": "0.2.0",
  "description": "Local agent workspace for running and coordinating CLI coding agents in parallel.",
  "license": "MIT",
  "homepage": "https://jasonsuhari.github.io/gridbash/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonsuhari/gridbash.git"
  },
  "bugs": {
    "url": "https://github.com/jasonsuhari/gridbash/issues"
  },
  "bin": {
    "gridbash": "npm/bin/gridbash.js"
  },
  "files": [
    "npm/bin/",
    "docs/devlogs/",
    "docs/releases/",
    "docs/AUTOMATED_REVIEW.md",
    "docs/REFERENCE.md",
    "docs/assets/gridbash-star-history.svg",
    "docs/RELEASING.md",
    "README.md",
    "LICENSE",
    "config.example.toml"
  ],
  "scripts": {
    "build": "cargo build --release",
    "devlog": "node npm/scripts/devlog.js",
    "install:local": "node npm/scripts/install-local.js",
    "prepare": "node npm/scripts/prepare.js",
    "release": "node npm/scripts/release.js",
    "test:issue-labeler": "node --test npm/scripts/issue-labeler.test.js",
    "test:launcher": "node --test npm/scripts/gridbash-launcher.test.js",
    "test:review-agent": "node --test npm/scripts/review-agent.test.js",
    "test:star-history": "node --test npm/scripts/update-star-history.test.js",
    "test:version": "node --test npm/scripts/version.test.js",
    "test": "cargo test"
  },
  "keywords": [
    "terminal",
    "terminal-grid",
    "terminal-ui",
    "agent-workspace",
    "agents",
    "ai-agents",
    "cli-agents",
    "coding-agents",
    "multi-agent",
    "agent-orchestration",
    "codex",
    "claude",
    "claude-code",
    "gemini",
    "gemini-cli",
    "aider",
    "openai",
    "tui",
    "ratatui",
    "pty",
    "conpty",
    "windows",
    "macos",
    "linux",
    "powershell",
    "git-bash",
    "developer-tools"
  ],
  "engines": {
    "node": ">=18"
  },
  "optionalDependencies": {
    "gridbash-win32-x64": "0.2.0",
    "gridbash-linux-x64": "0.2.0",
    "gridbash-linux-arm64": "0.2.0",
    "gridbash-darwin-arm64": "0.2.0",
    "gridbash-darwin-x64": "0.2.0"
  }
}
