    "gemini",
    "gemini-cli",
    "aider",
    "openai",
    "tui",
    "ratatui",
    "pty",
    "conpty",
    "windows",
    "powershell",
    "git-bash",
    "developer-tools"
  ],
  "engines": {
    "node": ">=18"
