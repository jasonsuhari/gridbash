{
  "name": "gridbash",
  "version": "0.1.4",
  "description": "Fast, beautiful terminal grids for running lots of CLI agents at once.",
  "license": "MIT",
  "homepage": "https://github.com/jasonsuhari/gridbash#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonsuhari/gridbash.git"
  },
  "bugs": {
    "url": "https://github.com/jasonsuhari/gridbash/issues"
  },
  "bin": {
    "gridbash": "npm/bin/gridbash.js"
  },
  "files": [
    "npm/bin/",
    "docs/devlogs/",
    "docs/releases/",
    "docs/RELEASING.md",
    "README.md",
    "LICENSE",
    "config.example.toml"
  ],
  "scripts": {
    "build": "cargo build --release",
    "devlog": "node npm/scripts/devlog.js",
    "install:local": "node npm/scripts/install-local.js",
    "prepare": "node npm/scripts/prepare.js",
    "release": "node npm/scripts/release.js",
    "test": "cargo test"
  },
  "keywords": [
    "terminal",
    "multiplexer",
    "agents",
    "codex",
    "claude",
    "tui",
    "pty",
    "conpty"
  ],
  "engines": {
    "node": ">=18"
  },
  "os": [
    "win32"
  ],
  "cpu": [
    "x64"
  ]
}
